---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import SectionBadge from "../../components/SectionBadge.astro";
import { formatDate } from "../../utils/date";
import { translatePath } from "../../utils/lang";

const lang = "en";
const allArticles = await getCollection("clanky");

const sortedArticles = allArticles
  .filter((article) => article.data.pubDate && article.data.lang === "en")
  .sort((a, b) => b.data.pubDate!.getTime() - a.data.pubDate!.getTime());
---

<Layout title="Articles and Knowledge Base">
  <section class="pt-12 pb-8 px-4 max-w-4xl mx-auto text-center">
    <SectionBadge> Our blog </SectionBadge>
    <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-green mb-6">
      Articles and <span class="italic">insights</span>
    </h1>
    <p class="text-lg text-dark-green/80 font-medium">
      We write about how to communicate climate change, share tips for teaching
      and reports from our past events.
    </p>
  </section>

  <section class="container mx-auto px-4 pb-8 max-w-5xl">
    {
      sortedArticles.length === 0 ? (
        <div class="text-center py-12 glass-card rounded-3xl">
          <p class="text-dark-green/60 text-lg">
            No articles yet. We'll add something soon!
          </p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 gap-8">
          {sortedArticles.map((article) => (
            <article class="glass-card rounded-3xl p-8 flex flex-col hover:shadow-xl transition-shadow duration-300 border border-brand-green/10">
              <div class="flex items-center gap-2 text-sm text-dark-green/60 font-medium mb-4">
                <Icon name="mdi:calendar-blank" class="w-4 h-4" />
                <time datetime={article.data.pubDate?.toISOString()}>
                  {article.data.pubDate ? formatDate(article.data.pubDate, "en") : ""}
                </time>
              </div>

              <h2 class="text-2xl font-serif font-bold text-brand-green mb-3 line-clamp-2">
                <a
                  href={translatePath(`/clanky/${article.id.replace(/\.md$/, "")}`, lang)}
                  class="hover:text-dark-green transition-colors"
                >
                  {article.data.title}
                </a>
              </h2>

              <p class="text-dark-green/80 mb-6 flex-grow line-clamp-3">
                {article.data.description}
              </p>

              <div class="mt-auto pt-4 border-t border-brand-green/10 flex items-center justify-between">
                <span class="text-sm font-bold text-brand-green">
                  {article.data.author}
                </span>
                <a
                  href={translatePath(`/clanky/${article.id.replace(/\.md$/, "")}`, lang)}
                  class="inline-flex items-center gap-1 text-sm font-bold text-dark-green hover:text-brand-green transition-colors group"
                >
                  Read more
                  <Icon
                    name="mdi:arrow-right"
                    class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"
                  />
                </a>
              </div>
            </article>
          ))}
        </div>
      )
    }
  </section>
</Layout>
