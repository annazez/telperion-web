---
const currentYear = new Date().getFullYear();
---

<!-- 
  mt-auto zatlačí patičku dolů, pokud je stránka poloprázdná.
  pb-6 zajistí, že "levituje" a nedotýká se úplného spodku prohlížeče.
-->
<footer class="mt-auto pt-16 pb-6 px-4 sm:px-6 lg:px-8 pointer-events-none">
  <!-- 
    Zde používáme tvůj sjednocený design: 
    glass-card, zaoblení (rounded-full) a stejný stín jako má navbar.
  -->
  <div class="mx-auto max-w-fit pointer-events-auto glass-card shadow-[0_8px_30px_rgb(0,0,0,0.06)] rounded-full px-8 py-3 transition-transform hover:-translate-y-1 duration-300">
    <div class="flex items-center justify-center text-center">
      <p class="text-sm text-dark-green font-medium tracking-wide">
        &copy; {currentYear} Telperion z.s. | Všechna práva vyhrazena.
      </p>
    </div>
  </div>
</footer>