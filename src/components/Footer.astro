---
const currentYear = new Date().getFullYear();
---

<!-- 
  Změna: Smazán margin-top (mt-8). 
  Patička je teď připravená se nalepit hned pod obsah.
-->.
<footer class="pb-6 px-4 sm:px-6 lg:px-8 pointer-events-none w-full">
  <div class="mx-auto max-w-fit pointer-events-auto glass-card shadow-[0_8px_30px_rgb(0,0,0,0.06)] rounded-full px-8 py-3 transition-transform hover:-translate-y-1 duration-300">
    <div class="flex flex-col md:flex-row items-center justify-center gap-2 text-center h-full">
      <p class="text-sm text-dark-green font-medium tracking-wide leading-none m-0 pt-1 md:pt-0">
        &copy; {currentYear} Telperion z.s
      </p>

      <div class="flex items-center justify-center h-full pt-1 md:pt-0">
        <div class="scale-75 opacity-90 hover:opacity-100 transition-opacity origin-center transform-gpu h-full flex items-center">
          <div id="wcb" class="carbonbadge flex items-center m-0"></div>
          <script src="https://unpkg.com/website-carbon-badges@1.1.3/b.min.js" defer></script>
        </div>
      </div>
    </div>
  </div>
</footer>
