---
const currentYear = new Date().getFullYear();
---

<!-- 
  Změna: Smazán margin-top (mt-8). 
  Patička je teď připravená se nalepit hned pod obsah.
-->
<footer class="pb-6 px-4 sm:px-6 lg:px-8 pointer-events-none w-full">
  <div class="mx-auto max-w-2xl pointer-events-auto glass-card shadow-[0_8px_30px_rgb(0,0,0,0.06)] rounded-[2rem] px-8 py-4 transition-transform hover:-translate-y-1 duration-300">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      
      <!-- Copyright text -->
      <p class="text-sm text-dark-green font-medium tracking-wide">
        &copy; {currentYear} Telperion z.s.
      </p>

      <!-- Website Carbon Badge -->
      <div class="flex items-center">
        <div id="wcb" class="carbonbadge wcb-d"></div>
        <!-- Externí skript pro načtení odznaku. Defer zajistí, že nebude blokovat načítání stránky -->
        <script src="https://unpkg.com/website-carbon-badges@1.1.3/b.min.js" defer></script>
      </div>

    </div>
  </div>
</footer>

<!-- 
  Drobný CSS fix pro Carbon Badge.
  Tento styl pomáhá odznaku, aby se lépe začlenil do naší zakulacené patičky
  a nerušil její design.
-->
<style is:global>
  #wcb.carbonbadge {
    --b1: #1a4d2e; /* dark-green z naší palety pro lepší vizuální splynutí */
    margin: 0 !important;
  }
</style>